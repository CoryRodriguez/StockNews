# ── Auth (REQUIRED in production) ─────────────────────────
# Generate with: openssl rand -hex 32
# Must be at least 32 characters. Server will refuse to start without it.
JWT_SECRET=change_me_to_a_random_secret
JWT_EXPIRES_IN=7d

# Dashboard password (set on first login via /setup)
# Must be 12+ chars with uppercase, lowercase, and number.

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins (REQUIRED in production)
# Example: https://yourdomain.com,https://www.yourdomain.com
# CORS_ORIGINS=

# ── Database (REQUIRED) ──────────────────────────────────
# Use a strong random password — generate with: openssl rand -hex 16
POSTGRES_USER=dtdash
POSTGRES_PASSWORD=change_me_to_a_random_password
POSTGRES_DB=dtdash
DATABASE_URL=postgresql://dtdash:YOUR_PASSWORD@postgres:5432/dtdash

# ── RTPR.io ───────────────────────────────────────────────
RTPR_API_KEY=your_rtpr_api_key_here

# ── Alpaca Markets ────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_API_SECRET=your_alpaca_secret_here
ALPACA_DATA_FEED=iex

# ── Benzinga ─────────────────────────────────────────────
BENZINGA_API_KEY=

# ── Financial Modeling Prep ──────────────────────────────
FMP_API_KEY=

# ── OpenAI (for headline reclassification) ───────────────
OPENAI_API_KEY=

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Paper Trading ──────────────────────────────────────────
# Set to "true" to enable automatic paper trading on news events.
PAPER_TRADING_ENABLED=false
PAPER_TRADE_QTY=10
PAPER_TRADE_SELL_DELAY_SEC=60
PAPER_TRADE_COOLDOWN_MIN=5
